# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL for QStash callbacks (production: https://your-domain.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Upstash QStash (https://console.upstash.com/qstash)
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Used by /api/cron/reminders (optional Vercel Cron: set CRON_SECRET)
CRON_SECRET=

# IANA timezone for “same day” assignment alerts and reminders
APP_TIMEZONE=America/Sao_Paulo
NEXT_PUBLIC_APP_TIMEZONE=America/Sao_Paulo
